{
  "name": "valyrian.js",
  "version": "1.1.0",
  "description": "Lightweight steel to forge PWAs. (Minimal Frontend Framework with server side rendering and other capabilities)",
  "repository": "git@github.com:Masquerade-Circus/valyrian.js-site.git",
  "author": "Masquerade <christian@masquerade-circus.net>",
  "license": "Apache-2.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "scripts": {
    "format": "prettier --write \"*.{js,json}\" \"client/**/*.js\" \"content/**/*.{js,json,md}\" \"server/**/*.js\" \"test/**/*.js\"",
    "format:check": "prettier --check \"*.{js,json}\" \"client/**/*.js\" \"content/**/*.{js,json,md}\" \"server/**/*.js\" \"test/**/*.js\"",
    "lint": "eslint . --ignore-pattern public --ignore-pattern tmp",
    "test": "node --test test/{client,content,pwa,server,tooling}/*.test.js content/snippets/catalog.test.js",
    "test:browser": "playwright test",
    "test:http": "node --test test/server/*.test.js",
    "build": "NODE_ENV=production node build.js",
    "ci": "bun run format:check && bun run lint && bun run test && bun run build",
    "dev": "NODE_ENV=development node --watch server.js",
    "start": "NODE_ENV=production node server.js"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "eslint": "8.57.1",
    "prettier": "3.9.5",
    "sass": "1.101.0",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "dragonglass": "2.0.1",
    "fastify": "5.10.0",
    "valyrian.js": "9.1.13"
  },
  "engines": {
    "bun": "1.3.14",
    "node": "24.x"
  }
}
